@model ProductTypeColor

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
<div>
    <form asp-controller="ProductTypeColors" asp-action="Create">
        <div class="mb-3">
            <label asp-for="ProductTypeId" class="form-label">
                Product Type 
            </label>
            <input asp-for="ProductTypeId" class="form-control" readonly />
        </div>
        <div class="mb-3">
            <label asp-for="ColorId" class="form-label">
                Color
            </label>
            <select asp-for="ColorId" class="form-control">
                <option>-- Please Select -- </option>
                @foreach (var color in (List<Color>)ViewBag.Colors )
                {
                    <option value="@color.Id">
                        @color.Name
                    </option>
                }
            </select>
            <div>
                <a class="btn btn-secondary"
                   asp-controller="ProductTypeColors"
                   asp-action="Index"
                   asp-route-productTypeId="@Model.ProductTypeId">
                    Cancel
                </a>
                <button type="submit" class="btn btn-primary">
                    Save
                </button>
            </div>
        </div>
    </form>
</div>