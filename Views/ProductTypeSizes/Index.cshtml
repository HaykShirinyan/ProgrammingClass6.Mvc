@model List<ProductTypeSize>

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

<div>
    <div class="mb-3">
        <a class="btn btn-primary"
        asp-controller="ProductTypeSizes"
        asp-action="Create"
        asp-route-productTypeId="@ViewBag.ProductTypeId">
            Add Size
        </a>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th>
                    Name
                </th>
                <th>
                    Description
                </th>
                <th>   
                    Actions
                </th>
            </tr>
        </thead>

        <tbody>
            @foreach (var productType in Model)
            {
                <tr>
                    <td>
                        @productType.Size.Name
                    </td>
                    <td>
                        @productType.Size.Description
                    </td>
                    <td>
                        <form asp-controller="ProductTypeSizes"
                              asp-action="Delete"
                              asp-route-productTypeId="@productType.ProductTypeId"
                              asp-route-sizeId="@productType.SizeId" />
                            <button type="submit" class="btn btn-danger">
                                Delete
                            </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>