@model ProductType

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

<h1 class="h3">
    Create Product Type
</h1>

<form asp-controller="ProductTypes" asp-action="Create">
    <div class="mb-3">
        <label asp-for="Title" class="form-label">
            Title
        </label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Brand" class="form-label">
            Brand
        </label>
        <textarea asp-for="Brand" class="form-control">
         </textarea>
        <span asp-validation-for="Brand" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Type" class="form-lable">
            Type
        </label>
        <input asp-for="Type" class="form-control" />
        <span asp-validation-for="Type" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <lable asp-for="Price" class="for-lable">
            Price
        </lable>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>
    <div>
        <a class="btn btn-secondary" asp-controller="ProductTypes" asp-action="Index">
            Cancel
        </a>
        <button class="btn btn-primary" type="submit">
            Save
        </button>
    </div>
</form>